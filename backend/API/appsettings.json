{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=mydatabase;Username=myuser;Password=mypassword"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false,
    "ContinueOnMigrationFailure": false
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ]
  },
  "Authentication": {
    "Jwt": {
      "Authority": "http://localhost:6060/realms/QPhising",
      "Audience": "account",
      "RequireHttpsMetadata": true
    }
  },
  "Keycloak": {
    "BaseUrl": "http://localhost:6060/",
    "Realm": "QPhising",
    "ClientId": "qphising",
    "ClientSecret": "gJcow0mlqvGAQbqtNQpV1ECxlBswN7eb"
  },
  "Redis": {
    "Configuration": "localhost:6379",
    "InstanceName": "QPhising"
  },
  "FeatureFlags": {
    "SwaggerEnabled": false
  },
  "HealthChecks": {
    "PostgreSql": {
      "Enabled": true,
      "ConnectionStringName": "DefaultConnection"
    },
    "Redis": {
      "Enabled": false
    }
  },
  "Tracking": {
    "VisitorPrivacy": {
      "HashPepper": ""
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "QPhising.API"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "TrackingReportBranding": {
      "LogoPath": "Assets/Branding/logo.png",
      "PrimaryColor": "#2563EB",
      "AccentColor": "#10B981",
      "TextColor": "#334155",
      "MutedTextColor": "#64748B",
      "BorderColor": "#E2E8F0",
      "SurfaceColor": "#F8FAFC",
      "CardColor": "#FFFFFF"
    }
  }
}
