{
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=__DB_HOST__;Port=5432;Database=__DB_NAME__;Username=__DB_USER__;Password=__DB_PASSWORD__"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ]
  },
  "Authentication": {
    "Jwt": {
      "Authority": "https://__KEYCLOAK_HOST__/realms/__REALM__",
      "Audience": "qphising-api",
      "RequireHttpsMetadata": true
    }
  },
  "Keycloak": {
    "BaseUrl": "https://__KEYCLOAK_HOST__",
    "Realm": "__REALM__",
    "ClientId": "qphising-api",
    "ClientSecret": "__SET_IN_RUNTIME_OR_SECRET_STORE__"
  },
  "Redis": {
    "Configuration": "__REDIS_HOST__:6379",
    "InstanceName": "QPhising"
  },
  "FeatureFlags": {
    "SetupWizardEnabled": true,
    "SwaggerEnabled": false
  },
  "Setup": {
    "RuntimeConfigFile": "appsettings.runtime.json",
    "AllowRuntimeOverrides": true
  },
  "HealthChecks": {
    "PostgreSql": {
      "Enabled": true,
      "ConnectionStringName": "DefaultConnection"
    },
    "Redis": {
      "Enabled": false
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "QPhising.API"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
