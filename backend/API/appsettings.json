{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Database": {
    "ConnectionString": "Host=postgres;Port=5432;Database=qphising;Username=postgres;Password=postgres"
  },
  "Redis": {
    "ConnectionString": "redis:6379",
    "TrackingDeduplicationWindowMinutes": 15,
    "TrackingTokenClockSkewSeconds": 30,
    "TrackingAbuseWindowMinutes": 1,
    "TrackingSuspiciousIpThreshold": 20,
    "TrackingIpRejectionThreshold": 50,
    "TrackingAggregateRetentionDays": 365,
    "AnalyticsDashboardCacheTtlSeconds": 300
  },
  "TrackingRetention": {
    "RawClickRetentionDays": 90,
    "AggregateRetentionDays": 365,
    "CleanupIntervalMinutes": 60,
    "CleanupBatchSize": 1000
  },
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/qphising",
    "Audience": "qphising-api",
    "RequireHttpsMetadata": false
  },
  "Smtp": {
    "Host": "mailhog",
    "Port": 1025,
    "Username": "qphising",
    "Password": "qphising",
    "FromAddress": "no-reply@qphising.local",
    "UseSsl": false
  },
  "BaseUrls": {
    "Gateway": "http://gateway:8080",
    "Frontend": "http://frontend"
  },
  "AllowedHosts": "*",
  "TrackingTokens": {
    "SigningKey": "qphising-local-dev-signing-key-please-change-2026",
    "ExpirationMinutes": 30,
    "Version": 1
  },
  "ExportStorage": {
    "BasePath": "/tmp/qphising-exports",
    "FileTtlDays": 7
  }
}