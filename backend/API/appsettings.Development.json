{
  "Database": {
    "ApplyMigrationsOnStartup": true,
    "ContinueOnMigrationFailure": false
  },
  "FeatureFlags": {
    "SwaggerEnabled": true
  },
  "Authentication": {
    "Jwt": {
      "RequireHttpsMetadata": false
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  }
}
