{
  "Database": {
    "ConnectionString": "Host=__DB_HOST__;Port=5432;Database=__DB_NAME__;Username=__DB_USER__;Password=__DB_PASSWORD__"
  },
  "Redis": {
    "ConnectionString": "__REDIS_HOST__:6379",
    "TrackingDeduplicationWindowMinutes": 15,
    "TrackingTokenClockSkewSeconds": 30,
    "TrackingAbuseWindowMinutes": 1,
    "TrackingSuspiciousIpThreshold": 20,
    "TrackingIpRejectionThreshold": 50,
    "TrackingAggregateRetentionDays": 365
  },
  "TrackingRetention": {
    "RawClickRetentionDays": 90,
    "AggregateRetentionDays": 365,
    "CleanupIntervalMinutes": 60,
    "CleanupBatchSize": 1000
  },
  "Keycloak": {
    "Authority": "https://__KEYCLOAK_HOST__/realms/__REALM__",
    "Audience": "qphising-api",
    "RequireHttpsMetadata": true
  },
  "Smtp": {
    "Host": "__SMTP_HOST__",
    "Port": 587,
    "Username": "__SMTP_USERNAME__",
    "Password": "__SMTP_PASSWORD__",
    "FromAddress": "no-reply@__MAIL_DOMAIN__",
    "UseSsl": true
  },
  "BaseUrls": {
    "Gateway": "https://__GATEWAY_HOST__",
    "Frontend": "https://__FRONTEND_HOST__"
  },
  "TrackingTokens": {
    "SigningKey": "__TRACKING_TOKEN_SIGNING_KEY_MIN_32_CHARS__",
    "ExpirationMinutes": 30,
    "Version": 1
  }
}
