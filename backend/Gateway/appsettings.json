{
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:4200",
      "https://localhost:4200"
    ]
  },
  "Authentication": {
    "Jwt": {
      "Authority": "https://__KEYCLOAK_HOST__/realms/__REALM__",
      "Audience": "qphising-gateway",
      "RequireHttpsMetadata": true
    }
  },
  "Keycloak": {
    "BaseUrl": "https://__KEYCLOAK_HOST__",
    "Realm": "__REALM__"
  },
  "Ocelot": {
    "ConfigFile": "ocelot.json"
  },
  "FeatureFlags": {
    "GatewayRateLimitingEnabled": false
  },
  "Setup": {
    "RuntimeConfigFile": "appsettings.runtime.json",
    "AllowRuntimeOverrides": true
  },
  "HealthChecks": {
    "DownstreamApi": {
      "Enabled": true,
      "Endpoint": "/health/live"
    }
  },
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console"
      }
    ],
    "Enrich": [ "FromLogContext" ],
    "Properties": {
      "Application": "QPhising.Gateway"
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  }
}
