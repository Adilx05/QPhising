{
  "$schema": "https://raw.githubusercontent.com/OpenAPITools/openapi-generator/master/modules/openapi-generator-cli/src/main/resources/config.schema.json",
  "generatorName": "typescript-angular",
  "outputDir": "src/app/core/api/generated",
  "globalProperty": {
    "apis": "",
    "models": "",
    "supportingFiles": ""
  },
  "additionalProperties": {
    "ngVersion": "19.2.0",
    "providedIn": "root",
    "withInterfaces": true,
    "stringEnums": true,
    "serviceSuffix": "Api",
    "modelPropertyNaming": "original",
    "enumPropertyNaming": "original",
    "fileNaming": "kebab-case",
    "useSingleRequestParameter": true,
    "useSquareBracketsInArrayNames": true,
    "skipJsonSuffix": false
  }
}
