{
  "openapi": "3.0.1",
  "info": {
    "title": "QPhising API",
    "version": "v1"
  },
  "paths": {
    "/api/proxy-validation/assert-sync": {
      "post": {
        "tags": [
          "ProxyValidation"
        ],
        "operationId": "ProxyValidation_AssertSync",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AssertProxyContractSyncRequest"
              }
            }
          }
        },
        "responses": {
          "204": {
            "description": "No Content"
          },
          "409": {
            "description": "Conflict",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProxyContractSyncConflictResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/setup/status": {
      "get": {
        "tags": [
          "Setup"
        ],
        "operationId": "Setup_GetStatus",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetupStatusResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/setup/guard-decision": {
      "get": {
        "tags": [
          "Setup"
        ],
        "operationId": "Setup_GetGuardDecision",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetupGuardDecisionResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/setup/test-db": {
      "post": {
        "tags": [
          "Setup"
        ],
        "operationId": "Setup_TestDb",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TestDatabaseConnectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetupDependencyTestResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/setup/test-redis": {
      "post": {
        "tags": [
          "Setup"
        ],
        "operationId": "Setup_TestRedis",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TestRedisConnectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetupDependencyTestResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/setup/test-keycloak": {
      "post": {
        "tags": [
          "Setup"
        ],
        "operationId": "Setup_TestKeycloak",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TestKeycloakConnectionRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetupDependencyTestResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/setup/save": {
      "post": {
        "tags": [
          "Setup"
        ],
        "operationId": "Setup_Save",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaveSetupConfigurationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SetupStatusResult"
                }
              }
            }
          }
        }
      }
    },
    "/api/configuration": {
      "get": {
        "tags": [
          "Configuration"
        ],
        "operationId": "Configuration_GetCurrent",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuntimeConfigurationResult"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "Configuration"
        ],
        "operationId": "Configuration_Save",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/SaveRuntimeConfigurationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuntimeConfigurationResult"
                }
              }
            }
          }
        }
      },
      "patch": {
        "tags": [
          "Configuration"
        ],
        "operationId": "Configuration_Update",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UpdateRuntimeConfigurationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RuntimeConfigurationResult"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AssertProxyContractSyncRequest": {
        "type": "object",
        "required": [
          "swaggerContractPath",
          "proxyGenerationStampPath"
        ],
        "additionalProperties": false,
        "properties": {
          "swaggerContractPath": {
            "type": "string"
          },
          "proxyGenerationStampPath": {
            "type": "string"
          }
        }
      },
      "ProxyContractSyncConflictResponse": {
        "type": "object",
        "required": [
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "status": {
            "$ref": "#/components/schemas/ProxyDriftValidationStatus"
          },
          "message": {
            "type": "string",
            "nullable": true
          },
          "swaggerLastModifiedUtc": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "proxyGeneratedAtUtc": {
            "type": "string",
            "format": "date-time",
            "nullable": true
          },
          "suggestedRegenerationCommand": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "ProxyDriftValidationStatus": {
        "enum": [
          0,
          1,
          2,
          3
        ],
        "type": "integer",
        "format": "int32"
      },
      "SaveSetupConfigurationRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "databaseConnectionString": {
            "type": "string",
            "nullable": true
          },
          "redisConnectionString": {
            "type": "string",
            "nullable": true
          },
          "keycloakAuthority": {
            "type": "string",
            "nullable": true
          },
          "keycloakRealm": {
            "type": "string",
            "nullable": true
          },
          "keycloakClientId": {
            "type": "string",
            "nullable": true
          },
          "keycloakClientSecret": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "SetupDependencyTestResult": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "dependency": {
            "type": "string",
            "nullable": true
          },
          "succeeded": {
            "type": "boolean"
          },
          "failureReason": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "SetupReadinessState": {
        "enum": [
          0,
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      },
      "SetupAccessState": {
        "enum": [
          0,
          1
        ],
        "type": "integer",
        "format": "int32"
      },
      "SetupGuardDecisionResult": {
        "type": "object",
        "required": [
          "accessState",
          "recommendedRedirectPath"
        ],
        "additionalProperties": false,
        "properties": {
          "accessState": {
            "$ref": "#/components/schemas/SetupAccessState"
          },
          "isSetupCompleted": {
            "type": "boolean"
          },
          "allowSetupWizard": {
            "type": "boolean"
          },
          "allowMainApplication": {
            "type": "boolean"
          },
          "recommendedRedirectPath": {
            "type": "string"
          }
        }
      },
      "SetupStatusResult": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "isDatabaseConfigured": {
            "type": "boolean"
          },
          "isKeycloakConfigured": {
            "type": "boolean"
          },
          "isRedisConfigured": {
            "type": "boolean"
          },
          "readinessState": {
            "$ref": "#/components/schemas/SetupReadinessState"
          }
        }
      },
      "TestDatabaseConnectionRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "connectionString": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "TestKeycloakConnectionRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "authority": {
            "type": "string",
            "nullable": true
          },
          "realm": {
            "type": "string",
            "nullable": true
          },
          "clientId": {
            "type": "string",
            "nullable": true
          },
          "clientSecret": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "TestRedisConnectionRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "connectionString": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "SaveRuntimeConfigurationRequest": {
        "type": "object",
        "required": [
          "databaseConnectionString",
          "redisConnectionString",
          "keycloakAuthority",
          "keycloakRealm",
          "keycloakClientId",
          "keycloakClientSecret"
        ],
        "additionalProperties": false,
        "properties": {
          "databaseConnectionString": {
            "type": "string"
          },
          "redisConnectionString": {
            "type": "string"
          },
          "keycloakAuthority": {
            "type": "string"
          },
          "keycloakRealm": {
            "type": "string"
          },
          "keycloakClientId": {
            "type": "string"
          },
          "keycloakClientSecret": {
            "type": "string"
          }
        }
      },
      "UpdateRuntimeConfigurationRequest": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "databaseConnectionString": {
            "type": "string",
            "nullable": true
          },
          "redisConnectionString": {
            "type": "string",
            "nullable": true
          },
          "keycloakAuthority": {
            "type": "string",
            "nullable": true
          },
          "keycloakRealm": {
            "type": "string",
            "nullable": true
          },
          "keycloakClientId": {
            "type": "string",
            "nullable": true
          },
          "keycloakClientSecret": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "RuntimeConfigurationResult": {
        "type": "object",
        "required": [
          "updatedAtUtc"
        ],
        "additionalProperties": false,
        "properties": {
          "isDatabaseConfigured": {
            "type": "boolean"
          },
          "isRedisConfigured": {
            "type": "boolean"
          },
          "isKeycloakConfigured": {
            "type": "boolean"
          },
          "isReadyForProtectedRuntime": {
            "type": "boolean"
          },
          "updatedAtUtc": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}
