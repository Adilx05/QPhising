ASPNETCORE_ENVIRONMENT=Production
POSTGRES_DB=qphising
POSTGRES_USER=qphising
POSTGRES_PASSWORD=replace-with-production-secret
POSTGRES_PORT=5432
API_PORT=5050
GATEWAY_PORT=8080
REDIS_PORT=6379
JWT_AUTHORITY=https://keycloak.example.com/realms/QPhising
JWT_AUDIENCE=account
JWT_REQUIRE_HTTPS_METADATA=true
API_SWAGGER_ENABLED=false
API_APPLY_MIGRATIONS_ON_STARTUP=false
SETUP_ALLOW_RUNTIME_OVERRIDES=false
GATEWAY_FORWARD_ACCESS_TOKEN=true
TRACKING_HASH_PEPPER=replace-with-production-pepper
