{
  "Database": {
    "ConnectionString": "Host=__DB_HOST__;Port=5432;Database=__DB_NAME__;Username=__DB_USER__;Password=__DB_PASSWORD__"
  },
  "Redis": {
    "ConnectionString": "__REDIS_HOST__:6379"
  },
  "Keycloak": {
    "Authority": "https://__KEYCLOAK_HOST__/realms/__REALM__",
    "Audience": "qphising-api",
    "RequireHttpsMetadata": true
  },
  "Smtp": {
    "Host": "__SMTP_HOST__",
    "Port": 587,
    "Username": "__SMTP_USERNAME__",
    "Password": "__SMTP_PASSWORD__",
    "FromAddress": "no-reply@__MAIL_DOMAIN__",
    "UseSsl": true
  },
  "BaseUrls": {
    "Gateway": "https://__GATEWAY_HOST__",
    "Api": "https://__API_HOST__",
    "Frontend": "https://__FRONTEND_HOST__"
  },
  "RateLimiting": {
    "DefaultWindowSeconds": 60,
    "DefaultLimit": 120,
    "Rules": [
      {
        "PathPrefix": "/api/access/admin",
        "Limit": 30,
        "WindowSeconds": 60,
        "Methods": [
          "GET"
        ]
      },
      {
        "PathPrefix": "/api/v",
        "Limit": 240,
        "WindowSeconds": 60,
        "Methods": [
          "GET",
          "POST",
          "PUT"
        ]
      },
      {
        "PathPrefix": "/api",
        "Limit": 240,
        "WindowSeconds": 60,
        "Methods": [
          "GET",
          "POST",
          "PUT"
        ]
      }
    ]
  }
}
