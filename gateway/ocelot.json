{
  "Routes": [
    {
      "DownstreamPathTemplate": "/api/access/admin",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/api/access/admin",
      "UpstreamHttpMethod": ["Get"],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "RouteClaimsRequirement": {
        "role": "Admin"
      },
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 60,
        "Limit": 30
      }
    },
    {
      "DownstreamPathTemplate": "/api/access/operator",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/api/access/operator",
      "UpstreamHttpMethod": ["Get"],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "RouteClaimsRequirement": {
        "role": "Operator"
      },
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 60,
        "Limit": 60
      }
    },
    {
      "DownstreamPathTemplate": "/api/access/viewer",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/api/access/viewer",
      "UpstreamHttpMethod": ["Get"],
      "AuthenticationOptions": {
        "AuthenticationProviderKey": "Bearer"
      },
      "RouteClaimsRequirement": {
        "role": "Viewer"
      },
      "RateLimitOptions": {
        "EnableRateLimiting": true,
        "Period": "1m",
        "PeriodTimespan": 60,
        "Limit": 120
      }
    },
    {
      "DownstreamPathTemplate": "/api/health",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/api/health",
      "UpstreamHttpMethod": ["Get"]
    },
    {
      "DownstreamPathTemplate": "/health",
      "DownstreamScheme": "http",
      "DownstreamHostAndPorts": [
        {
          "Host": "api",
          "Port": 8080
        }
      ],
      "UpstreamPathTemplate": "/api-health",
      "UpstreamHttpMethod": ["Get"]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "http://gateway:8080",
    "RateLimitOptions": {
      "DisableRateLimitHeaders": false,
      "QuotaExceededMessage": "Gateway rate limit exceeded.",
      "HttpStatusCode": 429,
      "ClientIdHeader": "X-Client-Id"
    }
  }
}
