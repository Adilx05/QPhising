{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    }
  },
  "Database": {
    "ConnectionString": "Host=postgres;Port=5432;Database=qphising;Username=postgres;Password=postgres"
  },
  "Redis": {
    "ConnectionString": "redis:6379"
  },
  "Keycloak": {
    "Authority": "http://keycloak:8080/realms/qphising",
    "Audience": "qphising-api",
    "RequireHttpsMetadata": false
  },
  "Smtp": {
    "Host": "mailhog",
    "Port": 1025,
    "Username": "qphising",
    "Password": "qphising",
    "FromAddress": "no-reply@qphising.local",
    "UseSsl": false
  },
  "BaseUrls": {
    "Gateway": "http://gateway:8080",
    "Api": "http://api:8080",
    "Frontend": "http://frontend"
  },
  "AllowedHosts": "*",
  "RateLimiting": {
    "DefaultWindowSeconds": 60,
    "DefaultLimit": 120,
    "Rules": [
      {
        "PathPrefix": "/api/access/admin",
        "Limit": 30,
        "WindowSeconds": 60,
        "Methods": [
          "GET"
        ]
      },
      {
        "PathPrefix": "/api/v",
        "Limit": 240,
        "WindowSeconds": 60,
        "Methods": [
          "GET",
          "POST",
          "PUT"
        ]
      },
      {
        "PathPrefix": "/api",
        "Limit": 240,
        "WindowSeconds": 60,
        "Methods": [
          "GET",
          "POST",
          "PUT"
        ]
      }
    ]
  }
}
